    "@babel/parser": "^7.29.2",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "concurrently": "^9.2.1",
    "live-server": "^1.2.2",
    "rollup": "^4.60.2",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-copy-watch": "^0.0.1",
    "webpack-dev-server": "^5.2.3"
  }
