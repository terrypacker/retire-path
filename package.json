{
  "name": "@terrypacker/retire-path",
  "version": "1.0.0-alpha.1",
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "browser": "dist/index.umd.js",
  "scripts": {
    "build:index": "node scripts/build-index.js",
    "build": "rollup -c",
